{
  "dashboard": {
    "id": null,
    "title": "Stonks Trading Dashboard",
    "tags": ["stonks", "trading", "crypto"],
    "timezone": "UTC",
    "schemaVersion": 36,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Bot Equity (USD)",
        "type": "timeseries",
        "targets": [
          {
            "expr": "bot_equity_usd",
            "legendFormat": "{{bot_type}}/{{bot_instance_id}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "custom": {"lineWidth": 2, "fillOpacity": 10}
          }
        }
      },
      {
        "id": 2,
        "title": "Trades per Minute",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(bot_trades_total[1m])",
            "legendFormat": "{{bot_type}}/{{symbol}}/{{side}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "fieldConfig": {
          "defaults": {
            "unit": "t/min",
            "custom": {"lineWidth": 2}
          }
        }
      },
      {
        "id": 3,
        "title": "Current Drawdown %",
        "type": "gauge",
        "targets": [
          {
            "expr": "bot_drawdown_pct",
            "legendFormat": "{{bot_type}}/{{bot_instance_id}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 20}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Position Quantity",
        "type": "stat",
        "targets": [
          {
            "expr": "bot_position_quantity",
            "legendFormat": "{{symbol}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        }
      },
      {
        "id": 5,
        "title": "Heartbeat Age (seconds)",
        "type": "stat",
        "targets": [
          {
            "expr": "time() - (bot_heartbeat_total * 0)",
            "legendFormat": "{{bot_type}}/{{bot_instance_id}}"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 60},
                {"color": "red", "value": 300}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Trade Latency (ms)",
        "type": "heatmap",
        "targets": [
          {
            "expr": "rate(trade_latency_ms_bucket[5m])",
            "legendFormat": ""
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "heatmap": {
          "yAxis": {"unit": "ms", "logBase": 1}
        }
      },
      {
        "id": 7,
        "title": "Database Health",
        "type": "stat",
        "targets": [
          {
            "expr": "db_connection_health",
            "legendFormat": "{{db_type}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": "Unhealthy"}, "type": "value"},
              {"options": {"1": "Healthy"}, "type": "value"}
            ],
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Total Trades Today",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(bot_trades_total[24h])",
            "legendFormat": "{{bot_type}}/{{symbol}}"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24}
      },
      {
        "id": 9,
        "title": "Reconciliation Issues",
        "type": "stat",
        "targets": [
          {
            "expr": "increase(reconciliation_issues_total[24h])",
            "legendFormat": "{{venue}}/{{issue_type}}"
          }
        ],
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 24}
      },
      {
        "id": 10,
        "title": "API Requests",
        "type": "graph",
        "targets": [
          {
            "expr": "rate(api_requests_total[5m])",
            "legendFormat": "{{method}} {{endpoint}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}
      },
      {
        "id": 11,
        "title": "Application Logs",
        "type": "logs",
        "datasource": "Loki",
        "targets": [
          {
            "expr": "{job=\"stonks-api\"} | json",
            "legendFormat": ""
          }
        ],
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 32},
        "options": {
          "showTime": true,
          "wrapLogMessage": true
        }
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "templating": {
      "list": [
        {
          "name": "bot_type",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(bot_equity_usd, bot_type)"
        },
        {
          "name": "symbol",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(bot_trades_total, symbol)"
        }
      ]
    }
  },
  "overwrite": true
}
