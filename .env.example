# Database
DATABASE_URL=postgresql://user:pass@localhost/stonks_trading

# Trading Configuration
MODE=dry_run  # backtest, dry_run, live
SYMBOLS=BTCUSDT,ETHUSDT,XRPUSDT
INITIAL_CAPITAL=10000.0

# NEAT Configuration
TRANSACTION_FEE=0.001  # Must match NEAT/main.py default
GENERATIONS=30
POP_SIZE=150
EPISODE_STEPS=20160
DECISION_THRESHOLD=0.6

# Exchange API (Binance)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_BASE_URL=https://api.binance.com

# Exchange API (Bitso - optional)
BITSO_API_KEY=your_bitso_key_here
BITSO_API_SECRET=your_bitso_secret_here

# Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Storage (Tigris S3)
S3_ENDPOINT=https://s3.us-east-1.tigris.dev
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=stonks-trading-data

# Logging
LOG_LEVEL=INFO  # ERROR, WARNING, INFO, DEBUG
LOG_FORMAT=json  # json, console

# Risk Management
MAX_POSITION_PCT=0.95  # Max 95% in single position
MAX_DRAWDOWN_PCT=0.15  # Kill switch at 15% drawdown
MIN_TRADE_INTERVAL_MINUTES=15
MAX_TRADES_PER_DAY=40

# Development
DEBUG=false
PYTEST_CURRENT_TEST=false
